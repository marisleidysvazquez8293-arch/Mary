#--------------------------------------------------------------------
# UDG-PROYECTOS — Variables de Entorno
# Copia este archivo como .env y ajusta los valores locales
# NUNCA subas el archivo .env a Git
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost/udg_proyectos/public/'
app.defaultLocale = 'es'
app.timezone = 'America/Mexico_City'

#--------------------------------------------------------------------
# BASE DE DATOS
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = udg_proyectos
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# SESIONES
#--------------------------------------------------------------------
# Usa 'database' en producción, 'files' en local
session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
session.cookieName = 'udg_session'
session.expiration = 7200
session.savePath = WRITEPATH . 'session'
session.matchIP = false
session.timeToUpdate = 300
session.regenerateDestroy = false

#--------------------------------------------------------------------
# CORREO SMTP
#--------------------------------------------------------------------
email.fromEmail = noreply@udg.mx
email.fromName = 'UDG-Proyectos'
email.SMTPHost = smtp.udg.mx
email.SMTPUser = noreply@udg.mx
email.SMTPPass = TU_PASSWORD_AQUI
email.SMTPPort = 587
email.SMTPTimeout = 5
email.SMTPKeepAlive = false
email.SMTPCrypto = tls
email.protocol = smtp
email.mailType = html
email.charset = UTF-8

#--------------------------------------------------------------------
# SUBIDA DE ARCHIVOS
#--------------------------------------------------------------------
# Máximo 500 MB = 512000 KB
upload.maxSize = 512000
upload.allowedTypes = pdf|docx|doc|zip|mp4
upload.maxVersions = 10

#--------------------------------------------------------------------
# SEGURIDAD
#--------------------------------------------------------------------
security.csrfProtection = 'cookie'
security.tokenName = 'csrf_token'
security.cookieName = 'csrf_cookie'
security.expires = 7200
security.regenerate = true
